generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  expires      DateTime
  user         String
  User         User     @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

model User {
  id            String      @id @default(uuid())
  name          String?
  nickname      String?
  email         String?     @unique
  emailVerified DateTime?
  password      String?
  passwordSalt  String?
  avatar        String?
  bio           String?
  sessions      Session[]
  App           App[]
  Skills        Skills[]
  UserBrand     UserBrand[]
}

model UserBrand {
  icon String @id @db.VarChar(500)
  url  String @db.VarChar(200)
  user String
  User User   @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

model App {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  icon         String   @db.VarChar(500)
  url          String   @db.VarChar(200)
  hint         BigInt?  @default(0)
  visiable     Boolean  @default(false)
  requiresAuth Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         String
  User         User     @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

// 定义一个枚举类型
enum SkillsType {
  professional
  language
  technical
  software
  life
  academic
  social
}

model Skills {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  icon      String      @db.VarChar(500)
  url       String      @db.VarChar(200)
  visiable  Boolean     @default(false)
  type      SkillsType  @default(technical)
  typeName  String      @db.VarChar(100)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      String
  User      User        @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}