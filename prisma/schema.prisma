generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  expires      DateTime
  user         String
  User         User     @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

model User {
  id            String      @id @default(uuid())
  name          String?
  nickname      String?
  email         String?     @unique
  emailVerified DateTime?
  password      String?
  passwordSalt  String?
  avatar        String?
  bio           String?
  sessions      Session[]
  App           App[]
  Skills        Skills[]
  UserBrand     UserBrand[]
}

model UserBrand {
  icon String @id @db.VarChar(500)
  url  String @db.VarChar(200)
  user String
  User User   @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

model App {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  icon         String    @db.VarChar(500)
  url          String    @db.VarChar(200)
  group        String?   @db.VarChar(100)
  hint         BigInt?   @default(0)
  visiable     Boolean   @default(false)
  requiresAuth Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @updatedAt
  user         String?
  User         User?     @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

// 定义一个枚举类型
enum SkillsType {
  professional
  language
  technical
  software
  life
  academic
  social
}

model Skills {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  icon      String     @db.VarChar(500)
  url       String     @db.VarChar(200)
  visiable  Boolean    @default(false)
  type      SkillsType @default(technical)
  typeName  String     @db.VarChar(100)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      String
  User      User       @relation(fields: [user], references: [id], onDelete: Cascade)

  @@index([user])
}

// Isons
model Icon {
  name String @unique

  @@index([name])
}

// gitmojis
model GitMojis {
  name        String  @unique
  code        String  @db.VarChar(50)
  emoji       String  @db.VarChar(50)
  entity      String  @db.VarChar(50)
  description String  @db.VarChar(200)
  semver      String?
  color       String

  @@index([name])
}

// Github colors
model GithubColor {
  name  String @unique
  color String

  @@index([name])
}

// 定义一个枚举类型
enum VideoSource {
  douyin
  youtube
  iqiyi
  qq
  youku
  bilibili
  sohu
}

// Video
model Video {
  id       Int         @id @default(autoincrement())
  source   VideoSource @default(qq)
  name     String      @unique
  cover    String      @db.VarChar(500)
  url      String      @db.Text
  visiable Boolean     @default(true)

  @@index([id])
}

model OneTimePassword {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(50)
  email     String
  otp       String    @db.VarChar(100)
  expires   DateTime?
  createdAt DateTime  @default(now())

  @@index([id])
}

enum StockSource {
  SS // 上证
  SZ // 深证
}

enum StockType {
  ZS // 指数
  AG // A股
}

// Stock
model Stock {
  id     Int         @id @default(autoincrement())
  code   String      @unique @db.VarChar(50)
  source StockSource
  type   StockType

  @@index([id])
}

// 暂时未用上
model StockData {
  id        Int      @id @default(autoincrement())
  stock     Int
  date      DateTime
  open      Float
  close     Float
  high      Float
  low       Float
  volume    Float
  amount    Float
  change    Float
  percent   Float
  amplitude Float

  @@index([id])
}

// Device
model DeviceService {
  id        Int     @id @default(autoincrement())
  uuid      String  @default(uuid())
  isPrimary Boolean
  device    Int
  Device    Device  @relation(fields: [device], references: [id], onDelete: Cascade)

  @@index([id])
  @@index([device])
}

model Device {
  id        Int             @id @default(autoincrement())
  code      String          @unique @db.VarChar(50)
  name      String
  isDeleted Boolean         @default(false)
  services  DeviceService[]

  @@index([id])
}

// ==================== Stock Pool Models ====================

model Watchlist {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  market      String   @db.VarChar(10)
  type        String   @default("individual") @db.VarChar(20)
  cost        Decimal  @default(0) @db.Decimal(10, 4)
  alertsJson  String   @map("alerts_json") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("watchlist")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   @db.VarChar(50)
  code      String?  @db.VarChar(20)
  details   String?  @db.Text
  agentId   String?  @map("agent_id") @db.VarChar(100)
  timestamp DateTime @default(now()) @db.Timestamp(0)

  @@map("audit_log")
}

model AlertHistory {
  id             Int      @id @default(autoincrement())
  code           String   @db.VarChar(20)
  alertType      String   @map("alert_type") @db.VarChar(50)
  severity       String   @db.VarChar(20)
  message        String   @db.Text
  currentValue   Decimal? @map("current_value") @db.Decimal(10, 4)
  thresholdValue Decimal? @map("threshold_value") @db.Decimal(10, 4)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([code, alertType, createdAt])
  @@map("alert_history")
}
