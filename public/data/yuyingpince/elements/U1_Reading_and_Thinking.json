    {"id":"cd8810b7759d52ae4f432b31b9b63b40","en":"Good morning, Jane.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_01.mp3", "align":"center", "duration":"2273", "role":"Sally"},
    {"id":"a638f3a2b10b174d0da36147bd9efd01", "en":"Good morning, Sally.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_02.mp3", "align":"center", "duration":"2090", "role":"Jane"},
    {"id":"d189401143675da6c73e772f44c32cc3", "en":"Oh, Jane, this is my sister Kate. Kate, this is my friend Jane.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_03.mp3", "align":"center", "duration":"10267", "role":"Sally"},
    {"id":"3298d1b206ad8df00da7078fd1214b40", "en":"Nice to meet you, Jane.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_04.mp3", "align":"left", "duration":"2508", "role":"Kate"},
    {"id":"1e2fd441444abedf46cd4d5197e8ad35", "en":"Nice to meet you, too. Are those your parents?", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_05.mp3", "align":"center", "duration":"5147", "role":"Jane"},
    {"id":"70a6e42415d9375b0130db931fcb33e8", "en":"Yes, they are.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_06.mp3", "align":"center", "duration":"1960", "role":"Kate"},
    {"id":"460312668b57e6d56b3064fdfc2d6c77", "en":"And who's he?", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_07.mp3", "align":"center", "duration":"2247", "role":"Jane"},
    {"id":"718c2f03b5d75e7e384ca6bccf13845e", "en":"He's my brother, Paul.", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_08.mp3", "align":"center", "duration":"3109", "role":"Sally"},
    {"id":"07b83cfda9ac3561439adf2b80a7de11", "en":"Oh, I see. Well, have a good day!", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_09.mp3", "align":"center", "duration":"5277", "role":"Jane"},
    {"id":"098918f7138b28cceea61ca03d83c648", "en":"Thanks! You, too. Bye!", "src":"assets/demo/audios/CZYY_7S_U2_SA_2d_10.mp3", "align":"center", "duration":"3423", "role":"Sally/Kate"}
  ],
